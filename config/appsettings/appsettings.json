{
  "application": {
    "name": "TelemetryProcessingSystem",
    "version": "1.0.0",
    "environment": "development"
  },
  "processing": {
    "batch_size": 1000,
    "timeout_ms": 30000,
    "max_retries": 3,
    "thread_pool_size": 8
  },
  "telemetry": {
    "sample_rate": 1.0,
    "buffer_size_mb": 256,
    "flush_interval_ms": 5000
  }
}
